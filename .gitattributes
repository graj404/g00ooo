# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for shell scripts (they run on Linux/Raspberry Pi)
*.sh text eol=lf

# Force LF for Python files
*.py text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
